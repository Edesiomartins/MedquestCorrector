# =============================================================================
# Railway — variáveis do BACKEND (FastAPI) e do WORKER (Celery)
# =============================================================================

DATABASE_URL=<postgresql do Railway – referência ao plugin Postgres>
REDIS_URL=<redis do Railway – referência ao plugin Redis>

CORS_ORIGINS=https://medquestcorrector.up.railway.app

# LLM (correção via visão) — preencha com chave do OpenRouter
OPENROUTER_API_KEY=

# OCR manuscrito/documental low-cost — Google Cloud Vision
OCR_PROVIDER=google_vision
GOOGLE_VISION_API_KEY=

# Armazenamento de PDFs
UPLOAD_DIR=/tmp/medquest_uploads
MAX_UPLOAD_MB=40

# Limites da importação CSV
MAX_CSV_MB=5
MAX_CSV_ROWS=2000

# Worker Celery: mantenha baixo para evitar custo alto de memória no Railway.
CELERY_WORKER_CONCURRENCY=1
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_WORKER_MAX_TASKS_PER_CHILD=20

# JWT — defina uma chave forte em produção (ex.: openssl rand -hex 32)
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
